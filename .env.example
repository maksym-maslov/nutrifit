# PostgreSQL (used by postgres service)
# Dev defaults below are placeholders only — never use in production.
# Production credentials must come from a non-committed env file or secrets manager.
POSTGRES_DB=nutrifit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot (used by main-api service)
DB_USERNAME=postgres
DB_PASSWORD=postgres
# docker-compose builds this from POSTGRES_DB; set manually when running main-api outside Docker
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/nutrifit

# --- Docker HTTPS stack (https://localhost) ---
# See README.md for full setup. Run both scripts before first docker compose up:
#   scripts/generate-dev-certs.sh   (TLS for nginx)
#   scripts/generate-jwt-keys.sh    (JWT signing keys for main-api)
CORS_ALLOWED_ORIGINS=https://localhost
APP_COOKIE_SECURE=true
APP_FRONTEND_URL=https://localhost

# Mail (required for email verification and password reset)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Vite local dev (http://localhost:5173) ---
# Use these instead when running main-api outside Docker with npm run dev:
# CORS_ALLOWED_ORIGINS=http://localhost:5173
# APP_COOKIE_SECURE=false
# APP_FRONTEND_URL=http://localhost:5173

# --- Production overrides ---
# CORS_ALLOWED_ORIGINS=https://your-domain.com
# APP_COOKIE_SECURE=true
# APP_FRONTEND_URL=https://your-domain.com
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_USERNAME=your-smtp-user
# MAIL_PASSWORD=your-smtp-password

# ml-api (FastAPI)
# docker-compose builds this from POSTGRES_*; set manually when running ml-api outside Docker
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/nutrifit

# main-api -> ml-api integration (local dev only; docker-compose overrides with http://ml-api:8000)
ML_API_BASE_URL=http://localhost:8000
